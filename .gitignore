# Ignore the original source directory so it is never pushed to git or PyPI
original_source_do_not_publish/
core.py

# Ignore python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore build directories
build/
dist/
*.egg-info/

# Ignore virtual environments
venv/
.env/

# Ignore compiled binaries (let users compile them)
*.so
*.pyd
*.dylib
